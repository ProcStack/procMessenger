# procMessenger - LLM Chat Environment Variables
# Copy this file to .env and fill in your API keys.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Fallback model if Latest can't be resolved
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
OPENAI_API_KEY=
# Fallback model if Latest can't be resolved
OPENAI_MODEL=gpt-4o

# --- Llama (Local) ---
# Point to your local llama.cpp / Ollama / vLLM / LM Studio server
LLAMA_API_BASE=http://127.0.0.1:8080
LLAMA_MODEL=default
LLAMA_API_KEY=

# --- Local Model Paths ---
# Extra directories to scan for local model files (.gguf, .bin, .safetensors).
# Separate multiple paths with semicolons. The project's models/ folder is always checked first.
# Example: LLAMA_MODEL_PATHS=C:\Users\me\llmModels;D:\LLMs\downloaded
LLAMA_MODEL_PATHS=

# --- Local Inference (llama-cpp-python) ---
# Number of GPU layers to offload (-1 = all layers, 0 = CPU only)
LLAMA_GPU_LAYERS=-1
# Context window size in tokens (0 = auto-detect from model metadata)
#  ~16 gig vRAM = 131072
#  ~12 gig vRAM = 98304
#  ~8 gig vRAM = 65536
#  ~6 gig vRAM = 49152
#  ~4 gig vRAM = 32768
LLAMA_CONTEXT_SIZE=0

# --- System Prompts ---
# JSON dictionary mapping display labels to file paths (relative to LLM_Chat/ or absolute).
# System.md is always included as the "Default" entry.
# Example:
# SYSTEM_PROMPTS={"1st Person":"System_firstPerson.md","2nd Person":"System_secondPerson.md","3rd Person - He":"System_thirdPerson_he.md","3rd Person - She":"System_thirdPerson_she.md","3rd Person - They":"System_thirdPerson_they.md"}
SYSTEM_PROMPTS=
