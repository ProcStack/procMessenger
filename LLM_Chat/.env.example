# procMessenger — LLM Chat Environment Variables
# Copy this file to .env and fill in your API keys.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Fallback model if Latest can't be resolved
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
OPENAI_API_KEY=
# Fallback model if Latest can't be resolved
OPENAI_MODEL=gpt-4o

# --- Llama (Local) ---
# Point to your local llama.cpp / Ollama / vLLM / LM Studio server
LLAMA_API_BASE=http://127.0.0.1:8080
LLAMA_MODEL=default
LLAMA_API_KEY=

# --- Local Model Paths ---
# Extra directories to scan for local model files (.gguf, .bin, .safetensors).
# Separate multiple paths with semicolons. The project's models/ folder is always checked first.
# Example: LLAMA_MODEL_PATHS=C:\Users\me\llmModels;D:\LLMs\downloaded
LLAMA_MODEL_PATHS=

# --- Local Inference (llama-cpp-python) ---
# Number of GPU layers to offload (-1 = all layers, 0 = CPU only)
LLAMA_GPU_LAYERS=0
# Context window size in tokens
LLAMA_CONTEXT_SIZE=4096
